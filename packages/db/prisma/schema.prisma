datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

model User {
  id                    String            @id @default(uuid())
  email                 String            @unique
  password              String // scrypt hash: salt:hex
  name                  String?
  walletAddress         String?           @unique // Polygon address of the user's Privy embedded wallet (the signer/owner EOA)
  privyWalletId         String?           @unique // Privy's internal wallet ID, needed to request signatures
  depositWalletAddress  String?           @unique // Polymarket deposit wallet (ERC-1967 proxy) — holds pUSD, is the real maker/signer on orders
  depositWalletDeployed Boolean           @default(false) // Set once the WALLET-CREATE relayer tx is confirmed on-chain
  clobApiKey            String? // Derived Polymarket CLOB API credentials (L2 auth). These
  clobApiSecret         String? // cannot move funds on their own — every order still needs a
  clobApiPassphrase     String? // fresh EIP-712 signature from the real wallet via Privy.
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  ApiKeys               ApiKey[]
  Sessions              Session[]
  Markets               Market[]
  Orders                Order[]
  WatchlistItem         WatchlistItem[]
  RealPositions         RealPosition[]
  WebhookDeliveries     WebhookDelivery[]
}

// A real order placed against Polymarket's actual CLOB (mainnet). Separate
// from Order (the toy-exchange model above) on purpose — this tracks real
// money against real Polymarket markets.
model RealPosition {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  polymarketOrderId String // Order ID returned by Polymarket's CLOB
  tokenId           String // Polymarket CLOB token ID (the specific outcome)
  eventSlug         String
  side              String // BUY or SELL
  price             Float
  size              Float
  status            String   @default("SUBMITTED") // SUBMITTED, MATCHED, REJECTED, CANCELED
  createdAt         DateTime @default(now())
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model ApiKey {
  id        String   @id @default(uuid())
  key       String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  isActive  Boolean  @default(true)
}

model Market {
  id        String   @id @default(uuid())
  question  String
  closesAt  DateTime
  oracleId  String
  liquidity Float    @default(0)
  creatorId String
  creator   User     @relation(fields: [creatorId], references: [id])
  status    String   @default("OPEN") // OPEN, RESOLVED, CANCELED
  outcome   Boolean? // true = YES won, false = NO won, null = not yet resolved. Nothing sets this yet — no resolver is built.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Orders    Order[]
}

model Order {
  id        String   @id @default(uuid())
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String // YES or NO
  amount    Float
  price     Float
  createdAt DateTime @default(now())
}

// A user's saved live Polymarket event, with an optional price alert.
model WatchlistItem {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId    String // Polymarket Gamma event id
  slug       String
  title      String
  image      String?
  alertAbove Float?
  alertBelow Float?
  alertFired Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([userId, eventId])
}

model WebhookDelivery {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  webhookUrl String
  event      String // e.g. trade.executed
  payload    String // JSON stringified payload
  statusCode Int? // HTTP response status (e.g. 200, 500)
  status     String // SUCCESS, FAILED
  error      String? // Error message if failed
  createdAt  DateTime @default(now())
}
